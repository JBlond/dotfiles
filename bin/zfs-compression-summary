#!/bin/bash
MIN=$((1024*1024))
printf "%-40s %10s %10s %10s %6s %12s\n" "DATASET" "USED" "LOGICAL" "SAVED" "SAVED%" "COMPRESSION"

zfs list -H -o name | while read -r ds; do
  used_s=$(zfs get -H -o value used "$ds" 2>/dev/null) || used_s=""
  logical_s=$(zfs get -H -o value logicalused "$ds" 2>/dev/null) || logical_s=""
  comp_s=$(zfs get -H -o value compression "$ds" 2>/dev/null) || comp_s="unknown"

  [ -z "$used_s" ] || [ -z "$logical_s" ] && continue
  [ "$used_s" = "-" ] || [ "$logical_s" = "-" ] && continue

  to_bytes() {
    v="$1" 
    v="$(printf '%s' "$v" | tr -d '[:space:]')"
    if printf '%s' "$v" | grep -Eq '^[0-9]+$'; then 
        echo "$v"; return; 
    fi
    if ! printf '%s' "$v" | grep -Eq '^[0-9]+(\.[0-9]+)?[KMGTP]i?$'; then
      printf '%s' "$(printf '%s' "$v" | sed -E 's/[^0-9]//g')"; return
    fi
    num=$(printf '%s' "$v" | sed -E 's/([0-9]+(\.[0-9]+)?)[KMGTP]i?$/\1/i')
    unit=$(printf '%s' "$v" | sed -E 's/^[0-9]+(\.[0-9]+)?([KMGTP]i?)?$/\2/i' | tr '[:upper:]' '[:lower:]')
    scale=1
    case "$unit" in 
        k) scale=1024;; 
        m) scale=$((1024**2));; 
        g) scale=$((1024**3));; 
        t) scale=$((1024**4));; 
        p) scale=$((1024**5));; 
        '') scale=1;; 
    esac
    awk -v n="$num" -v s="$scale" 'BEGIN{ printf "%.0f", n*s }'
  }

  used_b=$(to_bytes "$used_s")
  logical_b=$(to_bytes "$logical_s")
  printf '%s\n' "$used_b" | grep -Eq '^[0-9]+$' || continue
  printf '%s\n' "$logical_b" | grep -Eq '^[0-9]+$' || continue
  [ "$logical_b" -ge "$MIN" ] || continue

  if [ "$logical_b" -le "$used_b" ]; then 
      saved_b=0; pct="N/A"; 
  else 
      saved_b=$((logical_b-used_b)); 
      pct=$((saved_b*100/logical_b))"%"; 
  fi

  human() {
    b=$1
    for u in B Ki Mi Gi Ti Pi; do
      if [ "$b" -lt 1024 ]; then 
          printf "%s%s" "$b" "$u"; 
          return; 
      fi
      b=$((b/1024))
    done
    printf "%sPi" "$b"
  }

  used_h=$(human "$used_b")
  logical_h=$(human "$logical_b")
  saved_h=$(human "$saved_b")

  printf "%-40s %10s %10s %10s %6s %12s\n" "$ds" "$used_h" "$logical_h" "$saved_h" "$pct" "$comp_s"
done
